@page "/Communication"
@using System.Diagnostics
@using Microsoft.AspNetCore.Authorization
@using ralsei_bot_discord.Types
@using RalseiBot.Web.Components.Widgets
@rendermode InteractiveServer
@inject IHttpClientFactory ClientFactory
@inject ILogger<Communication> Logger
@inject GeneralSharedState SharedState
@inject IJSRuntime Js

@attribute [Authorize]

@code {

    /// <summary>
    ///     The HTTP Client connected to the bot.
    /// </summary>
    private HttpClient? _client;

    /// <summary>
    ///     All the channels that the bot can reference.
    /// </summary>
    private List<ChannelData>? _channels;

    /// <summary>
    ///     The selected ID that the user has selected from the list.
    /// </summary>
    private string? _selectedId;

    /// <summary>
    ///     If the API is busy loading tasks, this boolean will be set to true.
    /// </summary>
    private bool _busyLoading = true;

    /// <summary>
    ///     When the bot initializes, initialize the first guild immediately.
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        _client = ClientFactory.CreateClient("RalseiBotBackend");

        _busyLoading = true;

        // Attempt to retrieve all guild data.
        // While receiving the data, display the loading throbber for the user so they don't spam the API with too many requests,
        // which would result in a rate limit.

        await SharedState.CheckIfImported(_client);
        await CreateChannelsGuild(SharedState.CurrentGuilds.First().Id);
    }

    /// <summary>
    ///     Create the channels for the user to interact with.
    /// </summary>
    /// <param name="guildId">The ID of the guild.</param>
    private async Task CreateChannelsGuild(ulong guildId)
    {
        _busyLoading = true;
        if (_client == null)
            return;
        _channels = await _client.GetFromJsonAsync<List<ChannelData>>($"Guild/channels/{guildId}");
        Debug.Assert(_channels != null, nameof(_channels) + " != null");
        _busyLoading = false;
    }

    /// <summary>
    ///     Reload the channel list with the current selected channel ID.
    /// </summary>
    private async Task ReloadChannelList()
    {
        if (ulong.TryParse(_selectedId, out var id))
        {
            await CreateChannelsGuild(id);
        }
    }

    private async Task ExecuteClipboard(ulong guildId)
    {
        await Js.InvokeVoidAsync("navigator.clipboard.writeText", guildId);
    }

}


<div>
    <p class="horizontal-alignment">
        <ImgIcon AssetLocation="@Assets["icons/info.png"]"/>
        A portal is a DM, Server Message and practically any kind of message the Bot User can receive. Select one down
        below.
    </p>


    <div class="channel-selection-panel bg-cover">
        @if (!_busyLoading && _channels != null)
        {
            <div class="horizontal-alignment">
                <select name="PortalSelectionBox" @bind="_selectedId" class="btn">
                    @foreach (var guild in SharedState.CurrentGuilds)
                    {
                        <option value="@(guild.Id)">@(guild.Name)</option>
                    }
                </select>
                <button class="btn" @onclick="ReloadChannelList">To Portal</button>
                <!-- Add to clipboard -->
                <button class="btn-no-back" @onclick="async () => await ExecuteClipboard(_channels.First().GuildId)">
                    <ImgIcon AssetLocation="@Assets["icons/clipboard.png"]"/>
                </button>
            </div>

            <!-- Channel selection section -->
            @foreach (var channel in _channels)
            {
                <div class="channel-button">
                    <a href="/Channel/@(channel.ChannelId)" class="channel-identifier">
                        <img
                            src="@Assets[channel.TypeChannel == ChannelType.Text ? "icons/text_channel.png" : "icons/voice_channel.png"]"
                            alt="Channel Type Icon"
                            width="16"
                            height="16"/>
                        @(channel.ChannelName)
                    </a>
                    <ActionPanel Client="_client" Id="@(channel.ChannelId)"/>
                </div>
            }
        }
        else
        {
            <LoadingThrobber ConnectionString="Loading Channels..."/>
        }
    </div>
</div>